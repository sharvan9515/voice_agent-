# Server
APP_ENV=development
PORT=8000
API_PREFIX=/api/v1

# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/voice_agent

# Redis
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=7200

# Anthropic Claude (required)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# OpenAI Whisper
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_DEFAULT_VOICE_ID=...
ELEVENLABS_MODEL_ID=eleven_turbo_v2

# Interview
INTERVIEW_MAX_QUESTIONS=10
INTERVIEW_DEFAULT_SKILL=general
INTERVIEW_DEFAULT_DIFFICULTY=intermediate

# Uploads
UPLOAD_DIR=./uploads
MAX_AUDIO_FILE_SIZE_MB=25

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
