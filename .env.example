# ── Server ────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/voice_agent

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=7200

# ── OpenAI (LLM + STT + TTS — single key for everything) ─────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ── Interview ─────────────────────────────────────────────────
INTERVIEW_MAX_QUESTIONS=10
INTERVIEW_DEFAULT_SKILL=general
INTERVIEW_DEFAULT_DIFFICULTY=intermediate

# ── Uploads & Logging ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_AUDIO_FILE_SIZE_MB=25
LOG_LEVEL=INFO
LOG_DIR=./logs
