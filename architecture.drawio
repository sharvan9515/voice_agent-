  <!-- PAGE 5: Interview State Machine -->
  <diagram id="state-machine" name="Interview State Lifecycle">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="sm_title" value="Interview State Lifecycle" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Start -->
        <mxCell id="sm_start" value="" style="ellipse;html=1;shape=doubleCircle;whiteSpace=wrap;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="530" y="80" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- States -->
        <mxCell id="st_init" value="Interview&#xa;Initialized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="150" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_ask" value="Asking&#xa;Question" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="260" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_wait" value="Awaiting&#xa;Candidate Response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="370" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_eval" value="Evaluating&#xa;Answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="480" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_store" value="Storing&#xa;Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="590" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_decide" value="Deciding&#xa;Next Step" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="700" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_complete" value="Interview&#xa;Complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="700" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st_report" value="Generating&#xa;Report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="800" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="sm_end" value="" style="ellipse;html=1;shape=doubleCircle;whiteSpace=wrap;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="805" y="890" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Transitions — all label cells are flat siblings at root level -->
        <mxCell id="tr0" style="endArrow=block;html=1;" edge="1" source="sm_start" target="st_init" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="tr1" style="endArrow=block;html=1;" edge="1" source="st_init" target="st_ask" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr1_l" value="startInterview()" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr2" style="endArrow=block;html=1;" edge="1" source="st_ask" target="st_wait" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr2_l" value="question presented" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr2">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr3" style="endArrow=block;html=1;" edge="1" source="st_wait" target="st_eval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr3_l" value="answer received" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr3">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr4" style="endArrow=block;html=1;" edge="1" source="st_eval" target="st_store" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr4_l" value="evaluation done" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr4">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr5" style="endArrow=block;html=1;" edge="1" source="st_store" target="st_decide" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr5_l" value="record saved" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr5">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr6" style="endArrow=block;html=1;curved=1;" edge="1" source="st_decide" target="st_ask" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="725"/>
              <mxPoint x="280" y="285"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="tr6_l" value="[more questions]" style="edgeLabel;html=1;fontSize=10;fontStyle=2;" vertex="1" connectable="0" parent="tr6">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-20" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr7" style="endArrow=block;html=1;" edge="1" source="st_decide" target="st_complete" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr7_l" value="[no more questions]" style="edgeLabel;html=1;fontSize=10;fontStyle=2;" vertex="1" connectable="0" parent="tr7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="tr8" style="endArrow=block;html=1;" edge="1" source="st_complete" target="st_report" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr8_l" value="generateReport()" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr8">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="tr9" style="endArrow=block;html=1;" edge="1" source="st_report" target="sm_end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tr9_l" value="report exported" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="tr9">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="10" as="offset"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- PAGE 6: Data Storage Schema -->
  <diagram id="data-storage" name="Data Storage Schema">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="ds_title" value="Voice-Based Interview Agent — Data Storage Schema" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- Tech stack note -->
        <mxCell id="ds_tech" value="Primary Store: PostgreSQL  |  Session Cache: Redis" style="text;html=1;fontSize=13;fontStyle=2;align=center;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="550" y="68" width="500" height="28" as="geometry"/>
        </mxCell>

        <!-- candidates table -->
        <mxCell id="tbl_candidates" value="&lt;b&gt;candidates&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="260" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_candidates_cols" value="[PK] candidate_id   UUID&#xa;      name          VARCHAR(120)&#xa;      email         VARCHAR(255) UNIQUE&#xa;      experience_level  VARCHAR(20)&#xa;      skill_scores   JSONB&#xa;      created_at    TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_candidates">
          <mxGeometry y="26" width="260" height="184" as="geometry"/>
        </mxCell>

        <!-- interview_sessions table -->
        <mxCell id="tbl_sessions" value="&lt;b&gt;interview_sessions&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="130" width="290" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_sessions_cols" value="[PK] session_id     UUID&#xa;[FK] candidate_id   UUID&#xa;      started_at    TIMESTAMPTZ&#xa;      ended_at      TIMESTAMPTZ&#xa;      total_score   NUMERIC(5,2)&#xa;      status        VARCHAR(20)&#xa;      created_at    TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_sessions">
          <mxGeometry y="26" width="290" height="204" as="geometry"/>
        </mxCell>

        <!-- conversation_logs table -->
        <mxCell id="tbl_convlogs" value="&lt;b&gt;conversation_logs&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="790" y="130" width="280" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_convlogs_cols" value="[PK] log_id         UUID&#xa;[FK] session_id     UUID&#xa;      role          VARCHAR(20)&#xa;      content       TEXT&#xa;      timestamp     TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_convlogs">
          <mxGeometry y="26" width="280" height="184" as="geometry"/>
        </mxCell>

        <!-- Redis cache note -->
        <mxCell id="redis_note" value="&lt;b&gt;Redis (Session Cache)&lt;/b&gt;&#xa;Key: session:{session_id}&#xa;Value: ConversationSession JSON&#xa;TTL: interview duration + 1h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=0;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="130" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- interview_records table -->
        <mxCell id="tbl_records" value="&lt;b&gt;interview_records&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="290" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_records_cols" value="[PK] record_id        UUID&#xa;[FK] session_id        UUID&#xa;      question_id       UUID&#xa;      question_text     TEXT&#xa;      question_skill    VARCHAR(80)&#xa;      question_difficulty VARCHAR(20)&#xa;      candidate_answer  TEXT&#xa;      timestamp         TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_records">
          <mxGeometry y="26" width="290" height="204" as="geometry"/>
        </mxCell>

        <!-- evaluation_results table -->
        <mxCell id="tbl_evals" value="&lt;b&gt;evaluation_results&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="440" width="280" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_evals_cols" value="[PK] eval_id          UUID&#xa;[FK] record_id         UUID&#xa;      score            NUMERIC(4,2)&#xa;      feedback         TEXT&#xa;      strengths        TEXT[]&#xa;      weaknesses       TEXT[]&#xa;      created_at       TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_evals">
          <mxGeometry y="26" width="280" height="194" as="geometry"/>
        </mxCell>

        <!-- interview_reports table -->
        <mxCell id="tbl_reports" value="&lt;b&gt;interview_reports&lt;/b&gt;" style="swimlane;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=0;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="820" y="440" width="290" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="tbl_reports_cols" value="[PK] report_id        UUID&#xa;[FK] session_id        UUID&#xa;[FK] candidate_id      UUID&#xa;      total_score      NUMERIC(5,2)&#xa;      strengths        TEXT[]&#xa;      weaknesses       TEXT[]&#xa;      summary          TEXT&#xa;      export_url       TEXT&#xa;      created_at       TIMESTAMPTZ" style="text;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;rotatable=0;html=1;fontSize=12;" vertex="1" parent="tbl_reports">
          <mxGeometry y="26" width="290" height="224" as="geometry"/>
        </mxCell>

        <!-- FOREIGN KEY RELATIONSHIPS — all flat siblings at root level -->

        <!-- candidates 1 --< interview_sessions -->
        <mxCell id="fk1" style="endArrow=ERmanyToOne;startArrow=ERmandOne;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="tbl_candidates" target="tbl_sessions" parent="1">
