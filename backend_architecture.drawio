        <mxCell id="dep4" value="config" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;strokeColor=#d79b00;fontSize=10;" edge="1" source="svc-box" target="cfg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Legend -->
        <mxCell id="leg" value="Layer Colours&#xa;────────────&#xa;Blue = API / HTTP&#xa;Green = Services&#xa;Purple = Repositories&#xa;Red = ORM Models&#xa;Yellow = Config / Schemas / Utils&#xa;Orange = External" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333;fontSize=11;align=left;" vertex="1" parent="1">
