        </mxCell>
        <mxCell id="f9" value="Claude API → JSON question" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;dashed=1;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="795" y="360"/></Array><Array as="targetPoint"><mxPoint x="455" y="360"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f10" value="update Redis state + ConversationLog" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="455" y="380"/></Array><Array as="targetPoint"><mxPoint x="1140" y="380"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f11" value="Q1 text" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="280" y="400"/></Array><Array as="targetPoint"><mxPoint x="120" y="400"/></Array></mxGeometry>
        </mxCell>

        <!-- ④ Submit answer -->
        <mxCell id="f12" value="POST /interviews/{id}/answer" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="120" y="480"/></Array><Array as="targetPoint"><mxPoint x="280" y="480"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f13" value="submit_answer(answer)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="280" y="495"/></Array><Array as="targetPoint"><mxPoint x="455" y="495"/></Array></mxGeometry>
        </mxCell>

        <!-- ⑤ Evaluate -->
        <mxCell id="f14" value="evaluate_answer(question, answer, skill, difficulty)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="455" y="580"/></Array><Array as="targetPoint"><mxPoint x="795" y="580"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f15" value="{ score, feedback, strengths, weaknesses }" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;dashed=1;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="795" y="600"/></Array><Array as="targetPoint"><mxPoint x="455" y="600"/></Array></mxGeometry>
        </mxCell>

        <!-- ⑥ Store Record + EvaluationResult -->
        <mxCell id="f16" value="record_repo.create() + eval_repo.create()" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#9673a6;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="455" y="670"/></Array><Array as="targetPoint"><mxPoint x="960" y="670"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f17" value="INSERT InterviewRecord + EvaluationResult" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#b85450;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="960" y="690"/></Array><Array as="targetPoint"><mxPoint x="1140" y="690"/></Array></mxGeometry>
        </mxCell>

        <!-- ⑦ Next question or end -->
        <mxCell id="f18" value="questions_asked &lt; MAX?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="730" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="f18y" value="YES → generate_question()" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="580" y="760"/></Array><Array as="targetPoint"><mxPoint x="795" y="760"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f18n" value="NO → end_session()" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="490" y="790"/></Array><Array as="targetPoint"><mxPoint x="630" y="790"/></Array></mxGeometry>
        </mxCell>

        <!-- ⑧ Report -->
        <mxCell id="f19" value="_finalize_interview() → ReportService.generate_report()" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="455" y="880"/></Array><Array as="targetPoint"><mxPoint x="795" y="880"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f20" value="Claude narrative → InterviewReport stored" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#b85450;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="795" y="900"/></Array><Array as="targetPoint"><mxPoint x="1140" y="900"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="f21" value="AnswerResponse + next question" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="sourcePoint"><mxPoint x="280" y="950"/></Array><Array as="targetPoint"><mxPoint x="120" y="950"/></Array></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════
       PAGE 3 · Data Model (ERD)
       ═══════════════════════════════════════════════════════════ -->
  <diagram id="page-erd" name="Data Model (ERD)">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="etitle" value="Data Model — Entity Relationship" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="700" height="36" as="geometry"/>
        </mxCell>

        <!-- Candidate -->
        <mxCell id="ent-cand" value="&lt;b&gt;Candidate&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;    name : String&#xa;    email : String (unique)&#xa;    experience_level : String&#xa;    skill_scores : JSON&#xa;    created_at : DateTime&#xa;    updated_at : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="260" height="200" as="geometry"/>
        </mxCell>

        <!-- InterviewSession -->
        <mxCell id="ent-sess" value="&lt;b&gt;InterviewSession&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;FK  candidate_id : UUID&#xa;    started_at : DateTime&#xa;    ended_at : DateTime?&#xa;    total_score : Float?&#xa;    status : Enum&#xa;    created_at : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="260" height="220" as="geometry"/>
        </mxCell>

        <!-- InterviewRecord -->
        <mxCell id="ent-rec" value="&lt;b&gt;InterviewRecord&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;FK  session_id : UUID&#xa;    question_id : String&#xa;    question_text : String&#xa;    question_skill : String&#xa;    question_difficulty : String&#xa;    candidate_answer : String&#xa;    timestamp : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="260" height="240" as="geometry"/>
        </mxCell>

        <!-- EvaluationResult -->
        <mxCell id="ent-eval" value="&lt;b&gt;EvaluationResult&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;FK  record_id : UUID (unique)&#xa;    score : Float (0–10)&#xa;    feedback : String&#xa;    strengths : String[]&#xa;    weaknesses : String[]&#xa;    created_at : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="80" width="260" height="220" as="geometry"/>
        </mxCell>

        <!-- ConversationLog -->
        <mxCell id="ent-log" value="&lt;b&gt;ConversationLog&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;FK  session_id : UUID&#xa;    role : String (agent|candidate)&#xa;    content : String&#xa;    timestamp : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="420" width="260" height="180" as="geometry"/>
        </mxCell>

        <!-- InterviewReport -->
        <mxCell id="ent-rep" value="&lt;b&gt;InterviewReport&lt;/b&gt;&#xa;──────────────────&#xa;PK  id : UUID&#xa;FK  session_id : UUID (unique)&#xa;FK  candidate_id : UUID&#xa;    total_score : Float&#xa;    strengths : String[]&#xa;    weaknesses : String[]&#xa;    summary : String&#xa;    export_url : String?&#xa;    created_at : DateTime" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="420" width="260" height="260" as="geometry"/>
        </mxCell>

        <!-- Redis (not a DB table, but part of data model) -->
        <mxCell id="ent-redis" value="&lt;b&gt;SessionState (Redis)&lt;/b&gt;&#xa;──────────────────&#xa;KEY  session:{id}&#xa;TTL  configurable (default 2h)&#xa;──────────────────&#xa;    session_id : str&#xa;    candidate_id : str&#xa;    status : str&#xa;    questions_asked : int&#xa;    conversation_history : list&#xa;    current_question : dict?&#xa;    started_at : str" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="260" height="220" as="geometry"/>
        </mxCell>

        <!-- Status Enum -->
        <mxCell id="ent-status" value="&lt;b&gt;SessionStatus (Enum)&lt;/b&gt;&#xa;──────────────────&#xa;INITIALIZED&#xa;IN_PROGRESS&#xa;COMPLETED&#xa;ABORTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Relationships -->
        <!-- Candidate 1 → * InterviewSession -->
        <mxCell id="rel1" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;fontSize=12;fontStyle=1;" edge="1" source="ent-cand" target="ent-sess" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- InterviewSession 1 → * InterviewRecord -->
        <mxCell id="rel2" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;fontSize=12;fontStyle=1;" edge="1" source="ent-sess" target="ent-rec" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- InterviewRecord 1 → 1 EvaluationResult -->
        <mxCell id="rel3" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERone;startArrow=ERone;fontSize=12;fontStyle=1;" edge="1" source="ent-rec" target="ent-eval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- InterviewSession 1 → * ConversationLog -->
        <mxCell id="rel4" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;fontSize=12;fontStyle=1;" edge="1" source="ent-sess" target="ent-log" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- InterviewSession 1 → 1 InterviewReport -->
        <mxCell id="rel5" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERone;startArrow=ERone;fontSize=12;fontStyle=1;" edge="1" source="ent-sess" target="ent-rep" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Candidate 1 → * InterviewReport -->
        <mxCell id="rel6" value="1" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;fontSize=12;fontStyle=1;dashed=1;" edge="1" source="ent-cand" target="ent-rep" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

