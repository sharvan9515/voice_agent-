        <mxCell id="dep2" value="uses" style="edgeStyle=orthogonalEdgeStyle;dashed=1;endArrow=open;strokeColor=#9673a6;fontSize=10;" edge="1" source="svc-box" target="rep-box" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
